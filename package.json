{
  "name": "dwl-viewer",
  "version": "1.0.0",
  "description": "Portable DWG/DXF Viewer using WebAssembly libdxfrw",
  "main": "dist/main.js",
  "author": "",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run watch\" \"electron .\"",
    "build": "tsc",
    "watch": "tsc --watch",
    "test:regression": "node scripts/regression-smoke.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@mlightcad/libdxfrw-web": "^0.1.0",
    "@mlightcad/libredwg-web": "^0.6.6",
    "dxf-parser": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.dwgviewer.app",
    "productName": "DWG Viewer",
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "files": [
      "dist/**/*",
      "public/**/*",
      "preload.js",
      "package.json",
      "!**/*.map"
    ],
    "asarUnpack": [
      "node_modules/@mlightcad/libdxfrw-web/dist/libdxfrw.wasm",
      "node_modules/@mlightcad/libredwg-web/wasm/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": "dwg",
        "name": "AutoCAD Drawing",
        "description": "DWG Drawing File",
        "role": "Viewer"
      },
      {
        "ext": "dxf",
        "name": "Drawing Exchange Format",
        "description": "DXF Drawing File",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
